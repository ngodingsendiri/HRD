# --- Neon Postgres ---
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# --- Auth (custom session cookie) ---
# openssl rand -base64 32  — REQUIRED in production (min 16 chars)
AUTH_SECRET=""

# Emails that always get ADMIN write access (comma-separated)
ADMIN_EMAILS="admin@example.com"

# --- create-admin script only (never commit real values) ---
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="use-a-strong-password"
# ADMIN_NAME="Admin"
# ADMIN_ROLE="ADMIN"          # or VIEWER
# REVOKE_SESSIONS="1"         # wipe sessions after password update
