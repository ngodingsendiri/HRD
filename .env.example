# --- Neon Postgres (get from Neon dashboard) ---
# DATABASE_URL: pooled connection string (used by the app at runtime).
# DIRECT_URL:   direct connection string (used by Prisma for migrations).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# --- Auth.js (GitHub OAuth) ---
# Create at: GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# Authorization callback URL: https://YOUR-DOMAIN/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Required for Vercel / preview deployments
AUTH_TRUST_HOST="true"

# --- Admin allowlist ---
# Comma-separated GitHub numeric user IDs permitted to use the admin app.
# Find yours at https://api.github.com/user while logged into GitHub.
ADMIN_GITHUB_IDS="12345678,87654321"
